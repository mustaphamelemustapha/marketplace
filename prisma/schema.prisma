datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(BUYER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile      Profile?
  products     Product[]  // For SELLERS
  orders       Order[]    // For BUYERS
  reviews      Review[]   // For BUYERS
  cartItems    CartItem[] // Persistent Cart for BUYERS
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName   String?
  lastName    String?
  avatarUrl   String?
  
  // Seller-specific details (nullable/optional for Buyers)
  businessName String?
  bio          String?
  phoneNumber  String?
  address      String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          String        @id @default(uuid())
  sellerId    String
  seller      User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  title       String
  description String
  price       Decimal       @db.Decimal(10, 2)
  stock       Int           @default(0)
  imageUrl    String?
  category    String
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  orderItems  OrderItem[]
  reviews     Review[]
  cartItems   CartItem[]

  @@index([sellerId])
  @@index([category])
  @@index([status])
}

model Order {
  id              String      @id @default(uuid())
  buyerId         String
  buyer           User        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  totalAmount     Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  paymentIntentId String?     @unique // Storing payment references from Stripe/Paystack
  shippingAddress String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  orderItems      OrderItem[]

  @@index([buyerId])
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity        Int
  priceAtPurchase Decimal  @db.Decimal(10, 2) // Snapshotted price at time of purchase
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

model Review {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  rating    Int      // 1 to 5 scale
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, buyerId]) // A buyer can review a product only once
  @@index([productId])
  @@index([buyerId])
}

model CartItem {
  id        String   @id @default(uuid())
  buyerId   String
  buyer     User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([buyerId, productId])
  @@index([buyerId])
}
